{
  "manifest_version": 3,
  "name": "Orvixa — Intelligence Layer for the Web",
  "version": "1.0.0",
  "description": "Universal Context Intelligence Layer embedding into any host platform (GitHub, LeetCode, Docs, Notion, LMS, SaaS).",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_title": "Toggle Orvixa Intelligence Dock (Ctrl+Shift+K)"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["contentScript.js"],
      "run_at": "document_end"
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "Toggle the Orvixa sidebar"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/*", "index.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
